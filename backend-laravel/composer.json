{
    "name": "asla/village-council-api",
    "description": "Asla Village Council API - مجلس قروي عسلة",
    "type": "project",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^11.0",
        "php-open-source-saver/jwt-auth": "^2.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "abandoned": "ignore",
            "ignore": {
                "PKSA-mdq4-51ck-6kdq": "debug-mode only",
                "PKSA-8qx3-n5y5-vvnd": "debug-mode only",
                "PKSA-w7xr-vk7n-rstm": "debug-mode only",
                "PKSA-q46n-4fdk-zjr4": "debug-mode only",
                "PKSA-qzrn-rnz3-85w1": "debug-mode only"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
